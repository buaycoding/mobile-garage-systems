<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Find Garages</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      :root {
        --green: #2e7d32;
        --green-dark: #1b5e20;
        --yellow: #f4c542;
        --orange: #f28c28;
        --light: #fffdf7;
        --surface: #ffffff;
      }

      body {
        background: var(--light);
        color: #1f2937;
      }

      .navbar {
        background: linear-gradient(90deg, var(--green-dark), var(--green)) !important;
      }

      .card {
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(27, 94, 32, 0.08);
        border: 1px solid #f3e4bc;
        background: var(--surface);
      }

      .btn-primary {
        background: var(--orange);
        border-color: var(--orange);
      }

      .btn-primary:hover {
        background: #c96a12;
        border-color: #c96a12;
      }

      .btn-outline-primary {
        color: var(--green-dark);
        border-color: var(--green);
      }

      .btn-outline-primary:hover {
        background: var(--green);
        color: #fff;
      }

      .alert-success {
        background: #eaf7ea;
        color: var(--green-dark);
        border-color: #cce8cd;
      }

      .alert-info {
        background: #fff8e1;
        color: #7a5a00;
        border-color: #f4c542;
      }

      h4, h5 {
        color: var(--green-dark);
      }

      iframe {
        border: 0;
        border-radius: 12px;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
      </div>
    </nav>

    <div class="container py-5">
      <% if (nearby) { %>
      <div class="alert alert-success mb-4">You’re seeing nearby garage options around your selected location.</div>
      <% } %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card p-4">
            <h4 class="mb-3">Search Garages</h4>
            <div class="mb-3">
              <label class="form-label">Search place</label>
              <input id="map-query" class="form-control" value="<%= query %>" placeholder="Kampala, Uganda" />
            </div>
            <div class="mb-3">
              <label class="form-label">Location</label>
              <select id="location-filter" class="form-select">
                <option value="all">All locations</option>
                <option value="kampala">Kampala</option>
                <option value="jinja">Jinja</option>
                <option value="mbarara">Mbarara</option>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label">Service</label>
              <select class="form-select">
                <option>Oil Change</option>
                <option>Brake Service</option>
                <option>Wheel Alignment</option>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label">Rating</label>
              <select class="form-select">
                <option>Any</option>
                <option>4+ stars</option>
                <option>5 stars</option>
              </select>
            </div>
            <button id="search-map" type="button" class="btn btn-primary w-100">Search Nearby</button>
          </div>
        </div>

        <div class="col-lg-8">
          <div class="card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h4 class="mb-0" id="garage-heading">Nearby Garages</h4>
              <a href="/garages?nearby=true&query=<%= encodeURIComponent(query) %>" class="btn btn-outline-primary btn-sm">Show Nearby</a>
            </div>
            <div class="alert alert-info mb-3" id="garage-info">Google Maps will show garages near your chosen location.</div>
            <div class="mb-3">
              <iframe id="map-frame" width="100%" height="280" src="https://www.google.com/maps?q=<%= encodeURIComponent(query) %>&output=embed"></iframe>
            </div>
            <div id="garage-list" class="row g-3">
              <div class="col-md-6 garage-card" data-location="kampala">
                <div class="card p-3 h-100">
                  <h5>Mobile Garage System</h5>
                  <p class="text-muted mb-2">Kampala • 4.8 ★</p>
                  <p>Oil changes, brakes, wheel alignment, and diagnostics.</p>
                  <a href="/booking?garage=Mobile%20Garage%20System&garageId=garage-1" class="btn btn-outline-primary btn-sm">Book Now</a>
                </div>
              </div>
              <div class="col-md-6 garage-card" data-location="jinja">
                <div class="card p-3 h-100">
                  <h5>City Wheel Works</h5>
                  <p class="text-muted mb-2">Jinja • 4.6 ★</p>
                  <p>Fast tire and suspension services with mobile support.</p>
                  <a href="/booking?garage=City%20Wheel%20Works&garageId=garage-2" class="btn btn-outline-primary btn-sm">Book Now</a>
                </div>
              </div>
              <div class="col-md-6 garage-card" data-location="mbarara">
                <div class="card p-3 h-100">
                  <h5>Roadside Rescue Garage</h5>
                  <p class="text-muted mb-2">Mbarara • 4.7 ★</p>
                  <p>Emergency repairs, towing support, and quick diagnostics.</p>
                  <a href="/booking?garage=Roadside%20Rescue%20Garage&garageId=garage-3" class="btn btn-outline-primary btn-sm">Book Now</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      const locationFilter = document.getElementById('location-filter');
      const garageCards = Array.from(document.querySelectorAll('.garage-card'));
      const heading = document.getElementById('garage-heading');
      const info = document.getElementById('garage-info');
      const mapFrame = document.getElementById('map-frame');
      const mapQuery = document.getElementById('map-query');
      const searchMap = document.getElementById('search-map');

      const applyFilter = () => {
        const value = locationFilter.value;
        let visibleCount = 0;

        garageCards.forEach((card) => {
          const match = value === 'all' || card.getAttribute('data-location') === value;
          card.style.display = match ? '' : 'none';
          if (match) visibleCount += 1;
        });

        heading.textContent = value === 'all' ? 'Nearby Garages' : `Nearby Garages in ${value.charAt(0).toUpperCase() + value.slice(1)}`;
        if (value === 'all') {
          info.textContent = 'Google Maps will show garages near your chosen location.';
        } else {
          info.textContent = `Showing garages near ${value.charAt(0).toUpperCase() + value.slice(1)}.`;
        }
      };

      const updateMap = () => {
        const query = mapQuery.value.trim() || 'Kampala, Uganda';
        mapFrame.src = `https://www.google.com/maps?q=${encodeURIComponent(query)}&output=embed`;
      };

      if (locationFilter) {
        locationFilter.addEventListener('change', applyFilter);
        applyFilter();
      }

      if (searchMap) {
        searchMap.addEventListener('click', updateMap);
      }

      if (mapQuery) {
        mapQuery.addEventListener('keydown', (event) => {
          if (event.key === 'Enter') {
            event.preventDefault();
            updateMap();
          }
        });
      }
    </script>
  </body>
</html>
