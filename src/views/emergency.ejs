<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Roadside Assistance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      body { background: #f7f9fc; }
      .card { border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
      </div>
    </nav>

    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card p-4">
            <h2 class="mb-3">Request Emergency Assistance</h2>
            <p class="text-muted">Get urgent help from a nearby garage in Uganda.</p>
            <form>
              <div class="mb-3">
                <label class="form-label">Location</label>
                <input class="form-control" placeholder="Enter your current location" />
              </div>
              <div class="mb-3">
                <label class="form-label">Issue</label>
                <select class="form-select">
                  <option>Flat tire</option>
                  <option>Engine breakdown</option>
                  <option>Battery issue</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input class="form-control" placeholder="0772xxxxxx" />
              </div>
              <button class="btn btn-primary w-100">Send Request</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
