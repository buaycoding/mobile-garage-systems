<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Booking Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      body { background: #f7f9fc; }
      .card { border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
      .status-badge { text-transform: capitalize; }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
      </div>
    </nav>

    <div class="container py-5">
      <div class="card p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="mb-0">Booking Management</h2>
          <span class="text-muted">Owner dashboard</span>
        </div>
        <div id="booking-list" class="table-responsive">
          <table class="table table-striped align-middle">
            <thead>
              <tr>
                <th>Customer</th>
                <th>Garage</th>
                <th>Service</th>
                <th>Date</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody id="booking-rows"></tbody>
          </table>
        </div>
      </div>
    </div>

    <script>
      const statusLabels = {
        pending: 'Pending',
        accepted: 'Accepted',
        in_progress: 'In Progress',
        completed: 'Completed',
        rejected: 'Rejected',
        cancelled: 'Cancelled'
      };

      const statusClasses = {
        pending: 'bg-secondary',
        accepted: 'bg-info',
        in_progress: 'bg-primary',
        completed: 'bg-success',
        rejected: 'bg-danger',
        cancelled: 'bg-warning text-dark'
      };

      function renderActions(booking) {
        if (booking.status === 'completed' || booking.status === 'rejected' || booking.status === 'cancelled') {
          return '<span class="text-muted">Closed</span>';
        }

        if (booking.status === 'pending') {
          return `
            <button class="btn btn-success btn-sm me-2" onclick="updateStatus('${booking.id}', 'accepted')">Accept</button>
            <button class="btn btn-danger btn-sm" onclick="updateStatus('${booking.id}', 'rejected')">Reject</button>
          `;
        }

        if (booking.status === 'accepted') {
          return `
            <button class="btn btn-primary btn-sm me-2" onclick="updateStatus('${booking.id}', 'in_progress')">Start</button>
            <button class="btn btn-warning btn-sm" onclick="updateStatus('${booking.id}', 'cancelled')">Cancel</button>
          `;
        }

        if (booking.status === 'in_progress') {
          return `
            <button class="btn btn-success btn-sm me-2" onclick="updateStatus('${booking.id}', 'completed')">Complete</button>
            <button class="btn btn-warning btn-sm" onclick="updateStatus('${booking.id}', 'cancelled')">Cancel</button>
          `;
        }

        return '';
      }

      async function loadBookings() {
        const response = await fetch('/api/booking-management');
        const data = await response.json();
        const rows = document.getElementById('booking-rows');
        rows.innerHTML = '';

        if (!data.success || !data.data.bookings.length) {
          rows.innerHTML = '<tr><td colspan="5" class="text-muted">No bookings yet.</td></tr>';
          return;
        }

        data.data.bookings.forEach((booking) => {
          const row = document.createElement('tr');
          row.innerHTML = `
            <td>${booking.customer}</td>
            <td>${booking.garage}</td>
            <td>${booking.service}</td>
            <td>${booking.bookingDate || '-'} ${booking.bookingTime || ''}</td>
            <td><span class="badge ${statusClasses[booking.status] || 'bg-secondary'} status-badge">${statusLabels[booking.status] || booking.status}</span></td>
            <td>${renderActions(booking)}</td>
          `;
          rows.appendChild(row);
        });
      }

      async function updateStatus(id, status) {
        const response = await fetch(`/api/booking-management/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status })
        });
        const result = await response.json();
        if (result.success) {
          await loadBookings();
        }
      }

      window.addEventListener('load', loadBookings);
    </script>
  </body>
</html>
