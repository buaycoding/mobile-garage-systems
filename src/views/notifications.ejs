<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notifications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      body { background: #f7f9fc; }
      .card { border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
      </div>
    </nav>

    <div class="container py-5">
      <div class="card p-4">
        <h2 class="mb-3">Notifications</h2>
        <ul class="list-group">
          <li class="list-group-item">Booking confirmed for Mobile Garage System</li>
          <li class="list-group-item">Payment received for your oil change</li>
          <li class="list-group-item">Emergency request accepted by a nearby garage</li>
        </ul>
      </div>
    </div>
  </body>
</html>
