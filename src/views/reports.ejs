<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reports</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      body { background: #f7f9fc; }
      .card { border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
      </div>
    </nav>

    <div class="container py-5">
      <div class="row g-4">
        <div class="col-md-3">
          <div class="card p-3"><h6>Revenue</h6><p class="display-6">UGX 18M</p></div>
        </div>
        <div class="col-md-3">
          <div class="card p-3"><h6>Bookings</h6><p class="display-6">310</p></div>
        </div>
        <div class="col-md-3">
          <div class="card p-3"><h6>Active Users</h6><p class="display-6">128</p></div>
        </div>
        <div class="col-md-3">
          <div class="card p-3"><h6>Pending Approvals</h6><p class="display-6">2</p></div>
        </div>
      </div>

      <div class="card p-4 mt-4">
        <h4 class="mb-3">Recent Reports</h4>
        <ul class="list-group">
          <li class="list-group-item">Daily revenue report</li>
          <li class="list-group-item">Weekly booking overview</li>
          <li class="list-group-item">Garage performance summary</li>
        </ul>
      </div>
    </div>
  </body>
</html>
