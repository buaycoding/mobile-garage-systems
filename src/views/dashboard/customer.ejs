<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      :root {
        --green: #2e7d32;
        --green-dark: #1b5e20;
        --yellow: #f4c542;
        --orange: #f28c28;
        --light: #fffdf7;
        --surface: #ffffff;
      }

      body {
        background: var(--light);
        color: #1f2937;
      }

      .navbar {
        background: linear-gradient(90deg, var(--green-dark), var(--green)) !important;
      }

      .card {
        border: 1px solid #f3e4bc;
        box-shadow: 0 8px 24px rgba(27, 94, 32, 0.08);
        background: var(--surface);
      }

      .btn-primary {
        background: var(--orange);
        border-color: var(--orange);
      }

      .btn-primary:hover {
        background: #c96a12;
        border-color: #c96a12;
      }

      .btn-outline-primary {
        color: var(--green-dark);
        border-color: var(--green);
      }

      .btn-outline-primary:hover {
        background: var(--green);
        color: #fff;
      }

      .btn-success {
        background: var(--green);
        border-color: var(--green);
      }

      h5, h6 {
        color: var(--green-dark);
      }

      .display-6 {
        color: var(--orange);
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
        <div class="d-flex align-items-center gap-2">
          <span class="navbar-text text-white">Customer Dashboard</span>
          <a href="/api/auth/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </div>
      </div>
    </nav>

    <div class="container py-4">
      <div class="card p-4 mb-4">
        <h5 class="mb-3">Quick Actions</h5>
        <div class="d-flex flex-wrap gap-2">
          <a href="/garages" class="btn btn-primary">View All Garages</a>
          <a href="/garages?nearby=true" class="btn btn-outline-primary">View Nearby Garages</a>
          <a href="/booking" class="btn btn-success">Book a Service</a>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Upcoming Services</h5>
            <p class="display-6"><%= upcomingServices || 0 %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Completed Bookings</h5>
            <p class="display-6"><%= completedBookings || 0 %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Saved Garages</h5>
            <p class="display-6"><%= savedGarages || 0 %></p>
          </div>
        </div>
      </div>

      <div class="card mt-4 p-4">
        <h5 class="mb-3">Your Recent Activity</h5>
        <ul class="list-group">
          <% if (recentActivity && recentActivity.length > 0) { %>
            <% recentActivity.forEach((item) => { %>
              <li class="list-group-item"><%= item %></li>
            <% }) %>
          <% } else { %>
            <li class="list-group-item text-muted">No recent activity yet.</li>
          <% } %>
        </ul>
      </div>
    </div>
  </body>
</html>
