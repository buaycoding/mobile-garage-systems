<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Owner Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
        <div class="d-flex align-items-center gap-2">
          <span class="navbar-text text-white">Garage Owner Dashboard</span>
          <a href="/api/auth/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </div>
      </div>
    </nav>

    <div class="container py-4">
      <div class="card p-4 mb-4">
        <h5 class="mb-3">Quick Actions</h5>
        <div class="d-flex flex-wrap gap-2">
          <a href="/create-garage" class="btn btn-primary">Add Service</a>
          <a href="/booking-management" class="btn btn-outline-primary">Create Work Order</a>
          <a href="/reports" class="btn btn-success">Add Spareparts</a>
          <a href="/reports" class="btn btn-outline-success">View Report</a>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Total Bookings</h5>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Revenue</h5>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Vehicles</h5>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Customers</h5>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Today Appointments</h5>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-4">
            <h5 class="card-title">Pending Work Orders</h5>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
      </div>

      <div class="row g-4 mt-1">
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Recent Bookings</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">No bookings yet</li>
            </ul>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Work Orders</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">No work orders yet</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="row g-4 mt-1">
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Mechanics Status</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">Mechanics status will appear here when assigned</li>
            </ul>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Low Stock Spare Parts</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">No low-stock items</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="card mt-4 p-4">
        <h5 class="mb-3">Recent Payments</h5>
        <ul class="list-group">
          <li class="list-group-item text-muted">No payments yet</li>
        </ul>
      </div>
    </div>
  </body>
</html>
