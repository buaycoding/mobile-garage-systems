<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      :root {
        --green: #2e7d32;
        --green-dark: #1b5e20;
        --yellow: #f4c542;
        --orange: #f28c28;
        --light: #fffdf7;
        --surface: #ffffff;
      }

      body {
        background: var(--light);
        color: #1f2937;
      }

      .navbar {
        background: linear-gradient(90deg, var(--green-dark), var(--green)) !important;
      }

      .card {
        border: 1px solid #f3e4bc;
        box-shadow: 0 8px 24px rgba(27, 94, 32, 0.08);
        background: var(--surface);
      }

      .btn-primary {
        background: var(--orange);
        border-color: var(--orange);
      }

      .btn-primary:hover {
        background: #c96a12;
        border-color: #c96a12;
      }

      .btn-outline-primary,
      .btn-outline-success {
        color: var(--green-dark);
        border-color: var(--green);
      }

      .btn-outline-primary:hover,
      .btn-outline-success:hover {
        background: var(--green);
        color: #fff;
      }

      .btn-success {
        background: var(--green);
        border-color: var(--green);
      }

      h5, h6 {
        color: var(--green-dark);
      }

      .display-6 {
        color: var(--orange);
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
        <div class="d-flex align-items-center gap-2">
          <span class="navbar-text text-white">Admin Dashboard</span>
          <a href="/api/auth/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </div>
      </div>
    </nav>

    <div class="container py-4">
      <div class="card p-4 mb-4">
        <h5 class="mb-3">Admin Quick Actions</h5>
        <div class="d-flex flex-wrap gap-2">
          <a href="/garage-management" class="btn btn-primary">Approve / Reject Garages</a>
          <a href="/booking-management" class="btn btn-outline-primary">Monitor Bookings</a>
          <a href="/reports" class="btn btn-success">View Reports</a>
          <a href="/admin-activity" class="btn btn-outline-success">Review Complaints</a>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-md-3">
          <div class="card p-3">
            <h6>Total Users</h6>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card p-3">
            <h6>Garages</h6>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card p-3">
            <h6>Bookings</h6>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card p-3">
            <h6>Revenue</h6>
            <p class="display-6 text-muted">—</p>
          </div>
        </div>
      </div>

      <div class="row g-4 mt-1">
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Pending Garage Approvals</h5>
            <ul class="list-group">
              <% if (pendingApprovals && pendingApprovals.length > 0) { %>
                <% pendingApprovals.forEach((approval) => { %>
                  <li class="list-group-item">
                    <div class="fw-semibold"><%= approval.full_name %></div>
                    <div class="small text-muted"><%= approval.email %></div>
                    <% if (approval.phone) { %>
                      <div class="small text-muted"><%= approval.phone %></div>
                    <% } %>
                  </li>
                <% }) %>
              <% } else { %>
                <li class="list-group-item text-muted">No pending approvals yet</li>
              <% } %>
            </ul>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">User Management</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">Customers, owners, and admins will appear here once accounts are created</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="row g-4 mt-1">
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Service Categories</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">No categories added yet</li>
            </ul>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Platform-wide Reports</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">Reports will appear as bookings and payments are made</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="row g-4 mt-1">
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Complaints and Disputes</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">No complaints yet</li>
            </ul>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="card p-4">
            <h5 class="mb-3">Account Actions</h5>
            <ul class="list-group">
              <li class="list-group-item text-muted">Suspend or delete accounts from user management once needed</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
