<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      body { background: #f7f9fc; }
      .card { border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
      </div>
    </nav>

    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card p-4">
            <h2 class="mb-3">Complete Payment</h2>
            <p class="text-muted">Book now and settle your service fee securely.</p>
            <div class="mb-4 p-3 bg-light rounded">
              <h5>Booking Summary</h5>
              <p class="mb-1">Service: Oil Change</p>
              <p class="mb-1">Garage: Mobile Garage System</p>
              <p class="mb-0">Amount: UGX 120,000</p>
            </div>
            <form>
              <div class="mb-3">
                <label class="form-label">Payment Method</label>
                <select class="form-select">
                  <option>MTN Mobile Money</option>
                  <option>Airtel Money</option>
                  <option>Card</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input class="form-control" placeholder="0772xxxxxx" />
              </div>
              <button class="btn btn-primary w-100">Pay Now</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
