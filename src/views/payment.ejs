<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      :root {
        --green: #2e7d32;
        --green-dark: #1b5e20;
        --orange: #f28c28;
        --light: #fffdf7;
        --surface: #ffffff;
      }

      body {
        background: var(--light);
        color: #1f2937;
      }

      .navbar {
        background: linear-gradient(90deg, var(--green-dark), var(--green)) !important;
      }

      .card {
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(27, 94, 32, 0.08);
        border: 1px solid #f3e4bc;
        background: var(--surface);
      }

      h2, h5 {
        color: var(--green-dark);
      }

      .btn-primary {
        background: var(--orange);
        border-color: var(--orange);
      }

      .btn-primary:hover {
        background: #c96a12;
        border-color: #c96a12;
      }

      .form-control, .form-select {
        border-color: #d8caa1;
      }

      .form-control:focus, .form-select:focus {
        border-color: var(--green);
        box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.15);
      }

      .bg-light {
        background-color: #fff8e1 !important;
      }

      .alert-success {
        background: #eaf7ea;
        color: var(--green-dark);
        border-color: #cce8cd;
      }

      .alert-danger {
        background: #fdecea;
        color: #b42318;
        border-color: #f5c2c7;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
      </div>
    </nav>

    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card p-4">
            <h2 class="mb-3">Complete Payment</h2>
            <p class="text-muted">Book now and settle your service fee securely using Mobile Money.</p>
            <div class="mb-4 p-3 bg-light rounded">
              <h5>Booking Summary</h5>
              <p class="mb-1">Service: Oil Change</p>
              <p class="mb-1">Garage: Mobile Garage System</p>
              <p class="mb-0">Amount: UGX <span id="amount-label"><%= defaultAmount.toLocaleString() %></span></p>
            </div>
            <form id="payment-form">
              <div class="mb-3">
                <label class="form-label">Payment Method</label>
                <select id="payment-method" name="method" class="form-select">
                  <option value="MTN Mobile Money" <%= defaultMethod === 'MTN Mobile Money' ? 'selected' : '' %>>MTN Mobile Money</option>
                  <option value="Airtel Money" <%= defaultMethod === 'Airtel Money' ? 'selected' : '' %>>Airtel Money</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input id="phone-number" name="phoneNumber" class="form-control" placeholder="0772xxxxxx" value="<%= defaultPhone %>" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Amount (UGX)</label>
                <input id="payment-amount" name="amount" type="number" class="form-control" value="<%= defaultAmount %>" min="1000" required />
              </div>
              <button class="btn btn-primary w-100">Pay Now</button>
            </form>
            <div id="payment-message" class="mt-3"></div>
          </div>
        </div>
      </div>
    </div>

    <script>
      const form = document.getElementById('payment-form');
      const message = document.getElementById('payment-message');
      const amountLabel = document.getElementById('amount-label');
      const amountInput = document.getElementById('payment-amount');

      amountInput.addEventListener('input', () => {
        amountLabel.textContent = Number(amountInput.value || 0).toLocaleString();
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        message.innerHTML = '';

        const payload = {
          amount: amountInput.value,
          method: document.getElementById('payment-method').value,
          phoneNumber: document.getElementById('phone-number').value
        };

        try {
          const response = await fetch('/api/payments', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const result = await response.json();

          if (result.success) {
            message.innerHTML = `<div class="alert alert-success">${result.message}. Reference: ${result.data.payment.reference}</div>`;
          } else {
            message.innerHTML = `<div class="alert alert-danger">${result.message || 'Payment could not be started.'}</div>`;
          }
        } catch (error) {
          message.innerHTML = '<div class="alert alert-danger">Unable to start payment right now.</div>';
        }
      });
    </script>
  </body>
</html>
