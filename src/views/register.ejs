<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      :root {
        --green: #2e7d32;
        --green-dark: #1b5e20;
        --yellow: #f4c542;
        --orange: #f28c28;
        --light: #fffdf7;
        --surface: #ffffff;
      }

      body {
        background: var(--light);
        color: #1f2937;
      }

      .card {
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(27, 94, 32, 0.08);
        border: 1px solid #f3e4bc;
        background: var(--surface);
      }

      h2 {
        color: var(--green-dark);
      }

      .btn-primary {
        background: var(--orange);
        border-color: var(--orange);
      }

      .btn-primary:hover {
        background: #c96a12;
        border-color: #c96a12;
      }

      a {
        color: var(--green);
      }
    </style>
  </head>
  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-6">
          <div class="card p-4">
            <h2 class="mb-3">Create an account</h2>
            <p class="text-muted">Register as a customer or garage owner to start using the platform.</p>
            <form id="register-form" method="post" action="/api/auth/register">
              <div class="mb-3">
                <label class="form-label">Full name</label>
                <input name="fullName" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Phone</label>
                <input name="phone" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Role</label>
                <select name="role" class="form-select">
                  <option value="customer">Customer</option>
                  <option value="garage_owner">Garage Owner</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary w-100">Create account</button>
            </form>
            <div class="mt-3 text-center">
              <a href="/create-garage">Want to add a garage instead?</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      document.getElementById('register-form').addEventListener('submit', async (event) => {
        event.preventDefault();
        const form = event.target;
        const payload = {
          fullName: form.fullName.value,
          email: form.email.value,
          phone: form.phone.value,
          password: form.password.value,
          role: form.role.value
        };

        const response = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const result = await response.json();
        const message = document.createElement('div');
        message.className = result.success ? 'alert alert-success mt-3' : 'alert alert-danger mt-3';
        message.textContent = result.message || 'Request completed';
        form.appendChild(message);

        if (result.success) {
          if (payload.role === 'garage_owner') {
            window.location.href = '/login';
          } else {
            window.location.href = '/login';
          }
        }
      });
    </script>
  </body>
</html>
