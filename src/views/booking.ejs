<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Book a Service</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      :root {
        --green: #2e7d32;
        --green-dark: #1b5e20;
        --yellow: #f4c542;
        --orange: #f28c28;
        --light: #fffdf7;
        --surface: #ffffff;
      }

      body {
        background: var(--light);
        color: #1f2937;
      }

      .card {
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(27, 94, 32, 0.08);
        border: 1px solid #f3e4bc;
        background: var(--surface);
      }

      h2 {
        color: var(--green-dark);
      }

      .btn-primary {
        background: var(--orange);
        border-color: var(--orange);
      }

      .btn-primary:hover {
        background: #c96a12;
        border-color: #c96a12;
      }

      .btn-outline-primary {
        color: var(--green-dark);
        border-color: var(--green);
      }

      .btn-outline-primary:hover {
        background: var(--green);
        color: #fff;
      }

      .form-control, .form-select {
        border-color: #d8caa1;
      }

      .form-control:focus, .form-select:focus {
        border-color: var(--green);
        box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.15);
      }

      .alert-warning {
        background: #fff8e1;
        color: #7a5a00;
        border-color: #f4c542;
      }

      .alert-danger {
        background: #fdecea;
        color: #b42318;
        border-color: #f5c2c7;
      }
    </style>
  </head>
  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h2 class="mb-0">Book a Service</h2>
              <a href="/garages" class="btn btn-outline-primary btn-sm">Browse Garages</a>
            </div>
            <p class="text-muted">Choose a garage, service, and time to create a booking request.</p>
            <form id="booking-form" class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Garage</label>
                <input id="garage" name="garage" class="form-control" required value="<%= garage || '' %>" />
                <input type="hidden" id="garageId" name="garageId" value="<%= garageId || '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Service</label>
                <select id="service" name="service" class="form-select">
                  <option value="oil-change">Oil Change</option>
                  <option value="brake-service">Brake Service</option>
                  <option value="wheel-alignment">Wheel Alignment</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Date</label>
                <input type="date" id="bookingDate" name="bookingDate" class="form-control" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Time</label>
                <input type="time" id="bookingTime" name="bookingTime" class="form-control" required />
              </div>
              <div class="col-12">
                <label class="form-label">Amount (UGX)</label>
                <input type="number" id="totalAmount" name="totalAmount" class="form-control" value="120000" min="0" />
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary w-100">Create Booking</button>
              </div>
            </form>
            <div id="booking-message" class="mt-3"></div>
          </div>
        </div>
      </div>
    </div>

    <script>
      document.getElementById('booking-form').addEventListener('submit', async (event) => {
        event.preventDefault();
        const message = document.getElementById('booking-message');
        message.innerHTML = '';

        const token = localStorage.getItem('accessToken');
        if (!token) {
          message.innerHTML = '<div class="alert alert-warning">Please log in before creating a booking.</div>';
          return;
        }

        const payload = {
          garageId: document.getElementById('garageId').value || 'garage-1',
          serviceId: document.getElementById('service').value,
          vehicleId: 'vehicle-1',
          bookingDate: document.getElementById('bookingDate').value,
          bookingTime: document.getElementById('bookingTime').value,
          totalAmount: document.getElementById('totalAmount').value
        };

        try {
          const response = await fetch('/api/bookings', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(payload)
          });
          const result = await response.json();

          if (result.success) {
            message.innerHTML = '<div class="alert alert-success">Booking created successfully.</div>';
            event.target.reset();
          } else {
            message.innerHTML = `<div class="alert alert-danger">${result.message || 'Booking failed'}</div>`;
          }
        } catch (error) {
          message.innerHTML = '<div class="alert alert-danger">Unable to create booking right now.</div>';
        }
      });
    </script>
  </body>
</html>
