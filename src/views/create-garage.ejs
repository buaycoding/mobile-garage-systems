<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Garage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      :root {
        --green: #2e7d32;
        --green-dark: #1b5e20;
        --yellow: #f4c542;
        --orange: #f28c28;
        --light: #fffdf7;
        --surface: #ffffff;
      }

      body {
        background: var(--light);
        color: #1f2937;
      }

      .card {
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(27, 94, 32, 0.08);
        border: 1px solid #f3e4bc;
        background: var(--surface);
      }

      h2 {
        color: var(--green-dark);
      }

      .btn-primary {
        background: var(--orange);
        border-color: var(--orange);
      }

      .btn-primary:hover {
        background: #c96a12;
        border-color: #c96a12;
      }

      a {
        color: var(--green);
      }
    </style>
  </head>
  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card p-4">
            <h2 class="mb-3">Register your garage</h2>
            <p class="text-muted">List your garage, services, and contact details for customers across Uganda.</p>
            <form id="garage-form">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Garage name</label>
                  <input name="name" class="form-control" required />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Phone</label>
                  <input name="phone" class="form-control" required />
                </div>
                <div class="col-12">
                  <label class="form-label">Description</label>
                  <textarea name="description" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                  <label class="form-label">Address</label>
                  <input name="address" class="form-control" required />
                </div>
                <div class="col-12">
                  <button class="btn btn-primary">Create Garage</button>
                </div>
              </div>
            </form>
            <div class="mt-3">
              <a href="/register">Need an account first?</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      document.getElementById('garage-form').addEventListener('submit', async (event) => {
        event.preventDefault();
        const form = event.target;
        const payload = {
          name: form.name.value,
          description: form.description.value,
          phone: form.phone.value,
          address: form.address.value
        };

        const response = await fetch('/api/garage-management', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const result = await response.json();
        const message = document.createElement('div');
        message.className = result.success ? 'alert alert-success mt-3' : 'alert alert-danger mt-3';
        message.textContent = result.message || 'Request completed';
        form.appendChild(message);
      });
    </script>
  </body>
</html>
