<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Garage Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
      :root {
        --green: #2e7d32;
        --green-dark: #1b5e20;
        --yellow: #f4c542;
        --orange: #f28c28;
        --light: #fffdf7;
        --surface: #ffffff;
      }

      body {
        background: var(--light);
        color: #1f2937;
      }

      .navbar {
        background: linear-gradient(90deg, var(--green-dark), var(--green)) !important;
      }

      .card {
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(27, 94, 32, 0.08);
        border: 1px solid #f3e4bc;
        background: var(--surface);
      }

      .btn-primary {
        background: var(--orange);
        border-color: var(--orange);
      }

      .btn-primary:hover {
        background: #c96a12;
        border-color: #c96a12;
      }

      h2, h4, h6 {
        color: var(--green-dark);
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">Mobile Garage System</a>
      </div>
    </nav>

    <div class="container py-5">
      <div class="row g-4">
        <div class="col-lg-8">
          <div class="card p-4">
            <h2>Mobile Garage System</h2>
            <p class="text-muted">Kampala, Uganda • 4.8 ★ • Open today</p>
            <p>Trusted garage for oil changes, brake services, alignment, diagnostics, and fleet repairs.</p>
            <div class="row g-3 mt-3">
              <div class="col-md-4">
                <div class="card p-3 h-100">
                  <h6>Opening Hours</h6>
                  <p class="mb-0">Mon-Sat 8:00-18:00</p>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card p-3 h-100">
                  <h6>Contact</h6>
                  <p class="mb-0">+256772000111</p>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card p-3 h-100">
                  <h6>Address</h6>
                  <p class="mb-0">Kampala Road</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="card p-4">
            <h4>Services</h4>
            <ul class="list-group list-group-flush">
              <li class="list-group-item d-flex justify-content-between"><span>Oil Change</span><strong>UGX 120,000</strong></li>
              <li class="list-group-item d-flex justify-content-between"><span>Brake Service</span><strong>UGX 180,000</strong></li>
              <li class="list-group-item d-flex justify-content-between"><span>Wheel Alignment</span><strong>UGX 150,000</strong></li>
            </ul>
            <a href="/booking?garage=Mobile%20Garage%20System&garageId=garage-1" class="btn btn-primary w-100 mt-3">Book Now</a>
          </div>
        </div>
      </div>

      <div class="card p-4 mt-4">
        <h4>Customer Reviews</h4>
        <div class="mt-3">
          <p class="mb-1"><strong>Sarah</strong> • 5★</p>
          <p>Fast and reliable service. I loved the transparent pricing.</p>
        </div>
        <div class="mt-3">
          <p class="mb-1"><strong>Daniel</strong> • 4★</p>
          <p>Great staff and very professional.</p>
        </div>
      </div>
    </div>
  </body>
</html>
